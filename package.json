{
  "name": "ro-launcher",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "lint": "eslint src vite.config.ts",
    "format": "prettier --write src vite.config.ts",
    "format:check": "prettier --check src vite.config.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "cargo build -p ro-inputd && GDK_BACKEND=x11 WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev",
    "tauri:build": "cargo build -p ro-inputd --release && tauri build",
    "tauri:build:appimage": "cargo build -p ro-inputd --release && NO_STRIP=true tauri build --bundles appimage"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^1.24.0",
    "react": "^18",
    "react-dom": "^18",
    "zustand": "^5"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "prettier": "^3.9.5",
    "tailwindcss": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
